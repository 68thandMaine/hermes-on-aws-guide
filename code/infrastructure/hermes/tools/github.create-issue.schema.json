{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hermes.tools.github.create_issue",
  "title": "GitHubCreateIssue",
  "description": "Create a GitHub issue in a repository. Contract boundary between model proposal and worker execution.",
  "type": "object",
  "additionalProperties": false,
  "required": ["owner", "repository", "title"],
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "GitHub organization or user"
    },
    "repository": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "body": {
      "type": "string",
      "maxLength": 65536
    },
    "labels": {
      "type": "array",
      "items": { "type": "string", "maxLength": 64 },
      "maxItems": 10
    }
  }
}
